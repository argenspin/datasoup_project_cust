<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_project_timesheet_form" model="ir.ui.view">
        <field name="name">project.timesheet.form</field>
        <field name="model">project.timesheet</field>
        <field name="arch" type="xml">
            <form string="Project Timesheet">
                <sheet>
                    <group>
                        <group>
                            <field name="date" string="Date"/>
                            <field name="project_id" string="Project" readonly="1" force_save="1"/>
                            <field name="description" string="Description"/>
                            <field name="total_employees" string="Total Employees"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Work Details">
                            <field name="timesheet_line_ids">
                                <tree editable="bottom">
                                    <field name="date" string="Date" optional="hide"/>
                                    <field name="employee_id" string="Employee" options="{'no_create': True}"/>
                                    <field name="description" string="Description"/>
                                    <field name="hours" string="Hours" widget="float_time"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>

            </form>
        </field>
    </record>
</odoo>